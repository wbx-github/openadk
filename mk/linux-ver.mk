KERNEL_FILE_VER:=	7.0.3
KERNEL_RELEASE:=	1
KERNEL_VERSION:=	$(KERNEL_FILE_VER)-$(KERNEL_RELEASE)
KERNEL_HASH:=		0bedadbf5788693ddebbcc913c893f1a97349af79ddde7144c2a80b401959f1c
endif
